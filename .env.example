# Copy this file to .env in the repo root and edit values.
# .env is gitignored — never commit secrets.

# SQL Server instance: hostname, host\instance, or tcp:host,port
SQL_SERVER=localhost

# Initial database (-d). Tool calls can override per request where supported.
SQL_DATABASE=mydatabase

# 1 = pass sqlcmd -C (trust server certificate). Use for local dev / self-signed.
# 0 = omit -C (stricter; requires a trusted TLS chain from sqlcmd).
SQL_TRUST_CERT=1

# --- Optional: SQL Server authentication ---
# If both SQL_USER and SQL_PASSWORD are unset/empty, sqlcmd uses Windows Integrated Security (-E).
# SQL_USER=myuser
# SQL_PASSWORD=mysecret

# --- Alternative: native sqlcmd variable names (same effect as SQL_* above) ---
# SQLCMDSERVER=localhost
# SQLCMDDATABASE=mydatabase
# SQLCMD_TRUST_CERT=1
# SQLCMDUSER=myuser
# SQLCMDPASSWORD=mysecret
